{
  "name": "keet-dropin-module-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone test runner package for Keet drop-in scripts",
  "type": "commonjs",
  "scripts": {
    "compile": "node --check ./01_generate_keet_key.js && node --check ./02_room_invite_and_chat.js",
    "run:key": "node ./01_generate_keet_key.js",
    "run:room": "node ./02_room_invite_and_chat.js",
    "run:room:create": "node ./02_room_invite_and_chat.js --create-only"
  },
  "dependencies": {
    "blind-pairing-core": "^2.10.0",
    "hypercore-id-encoding": "^1.3.0",
    "hyperswarm": "^4.17.0"
  }
}
